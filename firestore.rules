rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /estimates/{estimateId} {
      // Admins can read any estimate. Regular users can only read their own.
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);

      // Collection queries are admin-only to avoid bulk data scraping.
      allow list: if isAdmin();

      // All writes go through trusted server code using the Admin SDK.
      allow create, update, delete: if false;
    }

    match /estimateRateLimits/{userId} {
      allow read, write: if false;
    }
  }
}
